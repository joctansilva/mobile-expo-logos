{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@features/*": [
        "./features/*"
      ],
      "@db/*": [
        "./db/*"
      ],
      "@lib/*": [
        "./lib/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "app-example"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
